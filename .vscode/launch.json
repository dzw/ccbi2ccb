{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug ccbi2ccb (MSYS2)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/Debug/ccbi2ccb.exe",
            "args": ["PbHUD.ccbi"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "miDebuggerPath": "D:\\msys64\\ucrt64\\bin\\gdb.exe",
            "environment": [
                {
                  "name": "PATH",
                  "value": "D:\\msys64\\ucrt64\\bin;${env:PATH}"
                },
                {
                  "name": "MSYSTEM",
                  "value": "UCRT64"
                }
              ],
            "preLaunchTask": "CMake: Build Debug"
        },
        {
