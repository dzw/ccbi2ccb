{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake",
            "args": ["-B", "build", "-A", "Win32"],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PATH": "D:\\Program Files\\JetBrains\\CLion 2021.2.1\\bin\\cmake\\win\\bin;${env:PATH}"
                }
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake: Build Debug",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "build", "--config", "Debug"],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PATH": "D:\\Program Files\\JetBrains\\CLion 2021.2.1\\bin\\cmake\\win\\bin;${env:PATH}"
                }
            },
            "group": { "kind": "build", "isDefault": true },
            "dependsOn": "CMake: Configure",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "CMake: Build Release",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "build", "--config", "Release"],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PATH": "D:\\Program Files\\JetBrains\\CLion 2021.2.1\\bin\\cmake\\win\\bin;${env:PATH}"
                }
            },
            "group": "build",
            "dependsOn": "CMake: Configure",
            "problemMatcher": "$msCompile"
        }
    ]
}
